# Copy to .env and adjust values:  cp .env.example .env
# Never commit .env (it is gitignored).

# ---------- MySQL ----------
MYSQL_DATABASE=twareshdenis
MYSQL_USER=twaresh
MYSQL_PASSWORD=change_me_db_password
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_PUBLISH_PORT=3306

# ---------- phpMyAdmin ----------
PMA_HOST=db
PMA_USER=root
PMA_PASSWORD=change_me_root_password
UPLOAD_LIMIT=64M

# ---------- Django / API ----------
DJANGO_SECRET_KEY=change-me-in-production-use-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:8080,http://localhost:8000

# ---------- Initial admin user (seed on first startup) ----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_admin_password
ADMIN_EMAIL=admin@twareshdenis.com

# ---------- App ----------
SITE_NAME=Twaresh Denis
GUNICORN_WORKERS=3

# ---------- Host ports (Docker publish) ----------
BACKEND_PORT=8000
FRONTEND_PORT=8080
PHPMYADMIN_PORT=8081

# ---------- Local development (without Docker) ----------
# Set USE_SQLITE=1 to use backend/db.sqlite3 instead of MySQL
USE_SQLITE=0
